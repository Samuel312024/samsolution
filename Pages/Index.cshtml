    <script>
        const elements = document.querySelectorAll('.fade-up');
        const observer = new IntersectionObserver(entries => {
            entries.forEach(entry => {
                if (entry.isIntersecting) {
                    entry.target.classList.add('active');
                }
            });
        }, { threshold: 0.16 });

        elements.forEach(el => observer.observe(el));
        document.getElementById("ano").textContent = new Date().getFullYear();
    </script>

    <script>
        (() => {
            const carouselRoot = document.querySelector('[data-carousel-root]');
            if (!carouselRoot) {
                return;
            }

            const track = document.querySelector('[data-carousel-track]');
            const slides = Array.from(document.querySelectorAll('[data-carousel-slide]'));
            const dotsContainer = document.querySelector('[data-carousel-dots]');
            const prevButton = document.querySelector('[data-carousel-prev]');
            const nextButton = document.querySelector('[data-carousel-next]');
            const titleElement = document.querySelector('[data-carousel-title]');
            const descriptionElement = document.querySelector('[data-carousel-description]');
            const counterElement = document.querySelector('[data-carousel-counter]');
            const totalElement = document.querySelector('[data-carousel-total]');
            const lightbox = document.querySelector('[data-lightbox]');
            const lightboxImage = document.querySelector('[data-lightbox-image]');
            const lightboxTitle = document.querySelector('[data-lightbox-title]');
            const lightboxDownload = document.querySelector('[data-lightbox-download]');
            const lightboxCloseButtons = Array.from(document.querySelectorAll('[data-lightbox-close]'));
            const slideDetails = slides.map((slide) => ({
                title: slide.dataset.slideTitle || '',
                description: slide.dataset.slideDescription || ''
            }));

            const dots = slides.map((_, index) => {
                const dot = document.createElement('button');
                dot.type = 'button';
                dot.className = `carousel-dot${index === 0 ? ' is-active' : ''}`;
                dot.setAttribute('aria-label', `Ir para o slide ${index + 1}`);
                dot.dataset.carouselDot = String(index);
                dotsContainer?.appendChild(dot);
                return dot;
            });

            let currentSlide = 0;
            let autoplayId = null;
            let isLightboxOpen = false;
            let previousFocusedElement = null;

            function setActiveSlide(index) {
                currentSlide = (index + slides.length) % slides.length;
                track.style.transform = `translateX(-${currentSlide * 100}%)`;

                slides.forEach((slide, slideIndex) => {
                    const isActive = slideIndex === currentSlide;
                    slide.setAttribute('aria-hidden', String(!isActive));
                });

                dots.forEach((dot, dotIndex) => {
                    dot.classList.toggle('is-active', dotIndex === currentSlide);
                });

                const details = slideDetails[currentSlide];
                titleElement.textContent = details.title;
                descriptionElement.textContent = details.description;
                counterElement.textContent = String(currentSlide + 1).padStart(2, '0');
            }

            function stopAutoplay() {
                if (autoplayId) {
                    window.clearInterval(autoplayId);
                    autoplayId = null;
                }
            }

            function startAutoplay() {
                if (isLightboxOpen) {
                    return;
                }

                stopAutoplay();
                autoplayId = window.setInterval(() => {
                    setActiveSlide(currentSlide + 1);
                }, 6500);
            }

            function restartAutoplay() {
                if (isLightboxOpen) {
                    return;
                }

                stopAutoplay();
                startAutoplay();
            }

            function openLightbox(trigger) {
                if (!lightbox || !lightboxImage || !lightboxTitle || !lightboxDownload) {
                    return;
                }

                previousFocusedElement = document.activeElement;
                isLightboxOpen = true;
                stopAutoplay();
                lightboxImage.src = trigger.dataset.imageSrc || '';
                lightboxImage.alt = trigger.dataset.imageAlt || trigger.querySelector('img')?.alt || '';
                lightboxTitle.textContent = trigger.dataset.lightboxTitle || lightboxImage.alt || 'Imagem ampliada';
                lightboxDownload.href = trigger.dataset.imageSrc || '#';

                if (trigger.dataset.downloadName) {
                    lightboxDownload.setAttribute('download', trigger.dataset.downloadName);
                } else {
                    lightboxDownload.removeAttribute('download');
                }

                lightbox.hidden = false;
                lightbox.setAttribute('aria-hidden', 'false');
                document.body.classList.add('lightbox-open');

                window.requestAnimationFrame(() => {
                    lightbox.classList.add('is-open');
                    lightbox.querySelector('.lightbox-close')?.focus();
                });
            }

            function closeLightbox() {
                if (!lightbox || lightbox.hidden) {
                    return;
                }

                isLightboxOpen = false;
                lightbox.classList.remove('is-open');
                lightbox.setAttribute('aria-hidden', 'true');
                document.body.classList.remove('lightbox-open');

                window.setTimeout(() => {
                    lightbox.hidden = true;
                    lightboxImage?.removeAttribute('src');
                }, 180);

                if (previousFocusedElement && typeof previousFocusedElement.focus === 'function') {
                    previousFocusedElement.focus();
                }

                startAutoplay();
            }

            prevButton?.addEventListener('click', () => {
                setActiveSlide(currentSlide - 1);
                restartAutoplay();
            });

            nextButton?.addEventListener('click', () => {
                setActiveSlide(currentSlide + 1);
                restartAutoplay();
            });

            dots.forEach((dot, index) => {
                dot.addEventListener('click', () => {
                    setActiveSlide(index);
                    restartAutoplay();
                });
            });

            slides.forEach((slide, index) => {
                const trigger = slide.querySelector('[data-lightbox-trigger]');
                trigger?.addEventListener('click', () => {
                    setActiveSlide(index);
                    openLightbox(trigger);
                });
            });

            lightboxCloseButtons.forEach((button) => {
                button.addEventListener('click', closeLightbox);
            });

            document.addEventListener('keydown', (event) => {
                if (event.key === 'Escape') {
                    closeLightbox();
                }
            });

            carouselRoot.addEventListener('mouseenter', stopAutoplay);
            carouselRoot.addEventListener('mouseleave', startAutoplay);
            carouselRoot.addEventListener('focusin', stopAutoplay);
            carouselRoot.addEventListener('focusout', () => {
                if (!isLightboxOpen) {
                    startAutoplay();
                }
            });

            if (totalElement) {
                totalElement.textContent = String(slides.length).padStart(2, '0');
            }

            setActiveSlide(0);
            startAutoplay();
        })();
    </script>

            event_label: nome
        });
      }
    </script>

    <style>
        :root {
            --bg-base: #020617;
            --panel: rgba(15, 23, 42, 0.74);
            --panel-strong: rgba(15, 23, 42, 0.92);
            --border: rgba(148, 163, 184, 0.18);
            --accent: #38bdf8;
            --accent-strong: #2563eb;
        }

        body {
            font-family: "Sora", sans-serif;
            background:
                radial-gradient(circle at top, rgba(37, 99, 235, 0.22), transparent 30%),
                radial-gradient(circle at 15% 20%, rgba(14, 165, 233, 0.14), transparent 20%),
                linear-gradient(180deg, #020617 0%, #020617 44%, #030712 100%);
        }

        .fade-up {
            opacity: 0;
            transform: translateY(40px);
            transition: all 0.8s ease;
        }

        .fade-up.active {
            opacity: 1;
            transform: translateY(0);
        }

        .hover-glow:hover {
            box-shadow: 0 0 28px rgba(59, 130, 246, 0.18);
        }

        .glass-panel {
            background: linear-gradient(180deg, rgba(15, 23, 42, 0.94) 0%, rgba(15, 23, 42, 0.78) 100%);
            border: 1px solid var(--border);
            box-shadow: 0 32px 80px rgba(2, 6, 23, 0.55);
            backdrop-filter: blur(18px);
        }

        .hero-orb {
            position: absolute;
            border-radius: 999px;
            filter: blur(100px);
            opacity: 0.38;
            pointer-events: none;
        }

        .carousel-shell {
            position: relative;
            overflow: hidden;
            border-radius: 28px;
            border: 1px solid rgba(96, 165, 250, 0.18);
            background:
                linear-gradient(180deg, rgba(12, 20, 36, 0.86), rgba(2, 6, 23, 0.96)),
                radial-gradient(circle at top right, rgba(56, 189, 248, 0.12), transparent 28%);
        }

        .carousel-track {
            display: flex;
            transition: transform 0.8s cubic-bezier(0.22, 1, 0.36, 1);
            will-change: transform;
        }

        .carousel-slide {
            position: relative;
            min-width: 100%;
            overflow: hidden;
        }

        .carousel-slide::after {
            display: none;
        }

        .carousel-frame {
            position: relative;
            aspect-ratio: 16 / 8.2;
            min-height: 340px;
            background: linear-gradient(145deg, rgba(15, 23, 42, 0.85), rgba(2, 6, 23, 1));
        }

        .carousel-image {
            display: block;
            width: 100%;
            height: 100%;
            object-fit: cover;
        }

        .carousel-shot {
            position: relative;
            display: block;
            width: 100%;
            height: 100%;
            padding: 0;
            border: 0;
            background: transparent;
            cursor: zoom-in;
        }

        .carousel-shot:focus-visible {
            outline: 3px solid rgba(96, 165, 250, 0.92);
            outline-offset: -3px;
        }

        .carousel-zoom {
            position: absolute;
            right: 1rem;
            bottom: 1rem;
            display: inline-flex;
            align-items: center;
            gap: 0.5rem;
            border-radius: 999px;
            border: 1px solid rgba(148, 163, 184, 0.18);
            background: rgba(2, 6, 23, 0.72);
            padding: 0.55rem 0.9rem;
            font-size: 0.7rem;
            font-weight: 600;
            letter-spacing: 0.08em;
            text-transform: uppercase;
            color: #e2e8f0;
            backdrop-filter: blur(16px);
            white-space: nowrap;
            max-width: calc(100% - 2rem);
        }

        .carousel-zoom-label-mobile {
            display: none;
        }

        .carousel-controls {
            pointer-events: none;
        }

        .carousel-arrow {
            width: 3rem;
            height: 3rem;
            border-radius: 999px;
            border: 1px solid rgba(148, 163, 184, 0.3);
            background: rgba(15, 23, 42, 0.66);
            color: #fff;
            transition: all 0.2s ease;
            pointer-events: auto;
        }

        .carousel-arrow:hover,
        .carousel-arrow:focus-visible {
            background: rgba(37, 99, 235, 0.82);
            border-color: rgba(96, 165, 250, 0.78);
            transform: translateY(-1px);
        }

        .carousel-dot {
            width: 0.85rem;
            height: 0.85rem;
            border-radius: 999px;
            border: 1px solid rgba(148, 163, 184, 0.42);
            background: rgba(15, 23, 42, 0.82);
            transition: all 0.25s ease;
        }

        .carousel-dot.is-active {
            width: 2.4rem;
            background: linear-gradient(90deg, #38bdf8, #2563eb);
            border-color: transparent;
        }

        .metric-card {
            background: linear-gradient(180deg, rgba(15, 23, 42, 0.92), rgba(15, 23, 42, 0.72));
            border: 1px solid rgba(96, 165, 250, 0.14);
        }

        body.lightbox-open {
            overflow: hidden;
        }

        .lightbox {
            position: fixed;
            inset: 0;
            z-index: 70;
            display: grid;
            place-items: center;
            padding: 1.25rem;
            background: rgba(2, 6, 23, 0.84);
            opacity: 0;
            visibility: hidden;
            transition: opacity 0.18s ease, visibility 0.18s ease;
        }

        .lightbox.is-open {
            opacity: 1;
            visibility: visible;
        }

        .lightbox-backdrop {
            position: absolute;
            inset: 0;
            border: 0;
            background: transparent;
        }

        .lightbox-panel {
            position: relative;
            z-index: 1;
            width: min(96vw, 1500px);
            max-height: 92vh;
            overflow: hidden;
            border-radius: 28px;
            border: 1px solid rgba(148, 163, 184, 0.22);
            background: linear-gradient(180deg, rgba(15, 23, 42, 0.98), rgba(2, 6, 23, 0.98));
            box-shadow: 0 40px 80px rgba(2, 6, 23, 0.55);
        }

        .lightbox-close {
            position: absolute;
            top: 1rem;
            right: 1rem;
            z-index: 2;
            width: 2.75rem;
            height: 2.75rem;
            border-radius: 999px;
            border: 1px solid rgba(148, 163, 184, 0.22);
            background: rgba(15, 23, 42, 0.82);
            color: #f8fafc;
        }

        .lightbox-image {
            display: block;
            width: 100%;
            max-height: calc(92vh - 7rem);
            object-fit: contain;
            background: #020617;
        }

        @@media (max-width: 768px) {
            .carousel-frame {
                min-height: 220px;
            }

            .carousel-zoom {
                right: 0.6rem;
                bottom: 0.6rem;
                font-size: 0.58rem;
                letter-spacing: 0.04em;
                padding: 0.42rem 0.62rem;
                max-width: calc(100% - 1.2rem);
            }

            .carousel-zoom-label {
                display: none;
            }

            .carousel-zoom-label-mobile {
                display: inline;
            }
        }
    </style>
</head>

